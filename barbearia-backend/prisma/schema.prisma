generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Status {
  PENDENTE
  CONCLUIDO
  CANCELADO
}

enum FormaPagamento {
  PIX
  CARTAO
  DINHEIRO
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  nome         String?
  telefone     String        @unique
  senha        String
  role         String        @default("cliente")
  createdAt    DateTime      @default(now())
  agendamentos Agendamento[]

  @@map("users")
}

model Servico {
  id           String        @id @default(uuid())
  name         String
  description  String?
  price        Decimal       @db.Decimal(10, 2)
  durationMin  Int
  category     String?
  imageUrl     String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  agendamentos Agendamento[]

  @@map("servicos")
}

model Agendamento {
  id              Int             @id @default(autoincrement())
  horario         DateTime
  forma_pagamento FormaPagamento?
  status          Status          @default(PENDENTE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  userId          Int
  user            User            @relation(fields: [userId], references: [id])

  servicoId       String
  servico         Servico         @relation(fields: [servicoId], references: [id])

  barbeiroId      Int?
  barbeiro        Barbeiro?       @relation("AgendamentoBarbeiro", fields: [barbeiroId], references: [id])

  historico       Historico?

  @@map("agendamentos")
}

model Historico {
  id            Int         @id @default(autoincrement())
  descricao     String?
  realizadoEm   DateTime    @default(now())

  agendamentoId Int         @unique
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id])

  @@map("historico")
}

model Barbeiro {
  id            Int           @id @default(autoincrement())
  nome          String
  email         String        @unique 
  senha         String                 
  especialidade String
  experiencia   String?
  imageUrl      String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  agendamentos  Agendamento[] @relation("AgendamentoBarbeiro")

  @@map("barbeiros")
}

model Horarios {
  id         Int     @id @default(autoincrement())
  diaSemana  String
  abertura   Int
  fechamento Int
  ativo      Boolean @default(true)

  @@map("horarios")
}